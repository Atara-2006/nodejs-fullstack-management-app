<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Art Whisper - פרטי יצירה</title>
    <style>
        :root { 
            --primary: #1a5e5d; 
            --accent: #7dd3d2; 
            --bg: #fdfdf5; 
            --danger: #c0392b;
            --text: #333;
        }
        body { 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            background: var(--bg); 
            margin: 0; 
            padding: 40px; 
            display: flex;
            justify-content: center;
            color: var(--text);
        }
        .container { 
            display: flex; 
            max-width: 1100px; 
            width: 100%;
            background: white; 
            border-radius: 30px; 
            overflow: hidden; 
            box-shadow: 0 15px 50px rgba(0,0,0,0.07); 
            min-height: 600px; 
        }
        .image-side { 
            flex: 1.2; 
            background: #f8f8f8;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .image-side img { 
            width: 100%; 
            height: 100%; 
            object-fit: cover; 
        }
        .content-side { 
            flex: 1; 
            padding: 60px; 
            text-align: right; 
            display: flex; 
            flex-direction: column; 
            justify-content: center; 
        }
        .brand { 
            color: var(--accent); 
            font-weight: bold; 
            letter-spacing: 2px; 
            font-size: 0.9em;
            margin-bottom: 10px;
            text-transform: uppercase;
        }
        h1 { 
            font-size: 3em; 
            color: var(--primary); 
            margin: 0; 
            font-family: 'Playfair Display', serif;
        }
        .artist-name { 
            color: #888; 
            font-size: 1.2em; 
            margin-top: 5px;
            margin-bottom: 25px; 
        }
        .description { 
            line-height: 1.8; 
            color: #555; 
            margin-bottom: 30px;
            font-size: 1.1em;
        }
        .price-tag { 
            font-size: 2.5em; 
            color: var(--primary); 
            font-weight: bold; 
            margin-bottom: 40px; 
        }
        .actions { 
            display: flex; 
            gap: 15px; 
        }
        .btn {
            padding: 12px 35px;
            border-radius: 50px;
            font-weight: bold;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.3s ease;
            border: none;
            font-size: 1em;
            display: none; 
        }
        .btn-edit { 
            background: var(--primary); 
            color: white; 
        }
        .btn-delete { 
            background: white; 
            color: var(--danger); 
            border: 2px solid var(--danger); 
        }
        .btn:hover { 
            transform: translateY(-3px); 
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }
        .back-link {
            margin-top: 35px;
            display: inline-block;
            color: var(--accent);
            text-decoration: none;
            font-weight: bold;
            transition: 0.2s;
        }
        .back-link:hover { color: var(--primary); }

        @media (max-width: 850px) {
            .container { flex-direction: column; }
            .image-side { height: 400px; }
            .content-side { padding: 40px; }
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="image-side">
            <img id="pImg" src="" alt="יצירת אמנות">
        </div>

        <div class="content-side">
            <div class="brand">Art Whisper Boutique</div>
            <h1 id="pTitle">טוען נתונים...</h1>
            <p id="pArtist" class="artist-name"></p>
            
            <p id="pDesc" class="description"></p>
            
            <div class="price-tag">₪ <span id="pPrice">0</span></div>
            
            <div class="actions">
                <button id="editBtn" class="btn btn-edit" onclick="goToEdit()">עריכת יצירה</button>
                <button id="deleteBtn" class="btn btn-delete" onclick="deleteItem()">מחיקת יצירה</button>
            </div>

            <a href="/paintings" class="back-link">← חזרה לגלריית היצירות</a>
        </div>
    </div>

    <script>
        const paintingId = window.location.pathname.split('/').pop();

        async function loadPainting() {
            try {
                
                const res = await fetch(`/paintings/api/${paintingId}`);
                if (!res.ok) throw new Error("לא ניתן למצוא את היצירה");
                
                const p = await res.json();
                const token = localStorage.getItem('token');

        
                document.getElementById('pImg').src = p.imageUrl;
                document.getElementById('pTitle').innerText = p.title;
                document.getElementById('pArtist').innerText = "אמן: " + (p.artist ? p.artist.username : "לא ידוע");
                document.getElementById('pDesc').innerText = p.description || "אין תיאור זמין עבור יצירה זו.";
                document.getElementById('pPrice').innerText = p.price;

               
                if (token) {
                    const user = JSON.parse(atob(token.split('.')[1])); 

                    
                    if (user.role === 'admin' || (p.artist && p.artist._id === user.id)) {
                        document.getElementById('editBtn').style.display = 'inline-block';
                    }

                    
                    if (user.role === 'admin') {
                        document.getElementById('deleteBtn').style.display = 'inline-block';
                    }
                }
            } catch (err) {
                console.error(err);
                alert("שגיאה בטעינת הפרטים. וודא שכתובת ה-URL תקינה.");
            }
        }

        function goToEdit() {
            window.location.href = `/paintings/edit/${paintingId}`;
        }

        async function deleteItem() {
            if (!confirm('אזהרה: האם למחוק את היצירה הזו לצמיתות?')) return;

            const token = localStorage.getItem('token');
            try {
                const res = await fetch(`/paintings/${paintingId}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': 'Bearer ' + token }
                });

                if (res.ok) {
                    alert('היצירה הוסרה בהצלחה');
                    window.location.href = '/paintings';
                } else {
                    const msg = await res.text();
                    alert('פעולה נכשלה: ' + msg);
                }
            } catch (err) {
                alert('שגיאת תקשורת עם השרת');
            }
        }
        loadPainting();
    </script>
</body>
</html>